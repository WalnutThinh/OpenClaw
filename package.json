{
  "name": "openclaw-enchante",
  "version": "1.1.2",
  "description": "OpenClaw Enchante - One-click installer",
  "license": "MIT",
  "main": "./out/main/index.js",
  "author": "Enchante Direction",
  "homepage": "https://enchante.cloud",
  "keywords": [
    "openclaw",
    "ai-agent",
    "telegram",
    "installer",
    "electron",
    "desktop-app",
    "one-click"
  ],
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run prepare-installer-assets && npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps && node scripts/patch-nsis-multiuser-ui.mjs",
    "prepare-installer-assets": "node scripts/regenerate-icons-from-openclaw.mjs && node scripts/write-installer-display-version.mjs && node scripts/generate-installer-sidebar.mjs && node scripts/encode-installer-license-nsis.mjs",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win-app-zip": "npm run build && electron-builder --win zip --publish never",
    "write:latest-json": "node scripts/write-latest-json.mjs",
    "build:win-app-zip:latest": "npm run build:win-app-zip && npm run write:latest-json",
    "publish:app-latest-s3": "node scripts/publish-app-latest-s3.mjs",
    "publish:e2e-s3": "node scripts/publish-e2e-s3.mjs",
    "package:launcher-zip": "node scripts/package-launcher-zip.mjs",
    "publish:launcher-zip-s3": "node scripts/publish-launcher-zip-s3.mjs",
    "build:win-setup": "node scripts/build-windows-bootstrapper.mjs",
    "build:win": "npm run build && electron-builder --win --publish always",
    "build:mac": "npm run build && electron-builder --mac --publish always",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:win-local": "npm run build:win-app-zip && npm run build:win-setup",
    "build:mac-local": "npm run build && electron-builder --mac --publish never",
    "release": "node scripts/release.mjs",
    "icons:openclaw": "node scripts/regenerate-icons-from-openclaw.mjs",
    "sync-to-enchante-site": "node scripts/sync-installer-to-enchante-site.mjs",
    "fetch-signed-installer": "node scripts/fetch-signed-release-artifact.mjs",
    "sync-signed-to-enchante-site": "npm run fetch-signed-installer && npm run sync-to-enchante-site",
    "publish-signed-installer-s3": "node scripts/publish-signed-installer-s3.mjs"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-updater": "^6.8.3",
    "i18next": "^25.8.13",
    "react-i18next": "^16.5.4"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vercel/blob": "^2.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "png-to-ico": "^2.1.8",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
